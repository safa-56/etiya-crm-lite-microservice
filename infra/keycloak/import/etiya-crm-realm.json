{
  "realm": "etiya-crm",
  "enabled": true,
  "displayName": "Etiya CRM Lite",

  "//_ssl": "Local dev icin http'ye izin ver (external isteklerde HTTPS zorunlu degil).",
  "sslRequired": "external",

  "//_ac3": "AC-3: Kullanici adi dogrulamasi buyuk/kucuk harf DUYARSIZ. Keycloak kullanici adlarini kucuk harfe cevirerek saklar; giris zaten case-insensitive'dir. Asagidaki attribute bunu acikca isaretler.",
  "attributes": {
    "userProfileEnabled": "true"
  },

  "//_ac6": "AC-6: Kullanici islem yapmayi biraktiktan 8 saat sonra yeniden giris. SSO oturum bosta kalma (idle) suresi = 28800 sn = 8 saat.",
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 36000,
  "ssoSessionIdleTimeoutRememberMe": 28800,
  "ssoSessionMaxLifespanRememberMe": 86400,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "offlineSessionIdleTimeout": 2592000,

  "//_ac5": "AC-5: 5 basarisiz denemeden sonra hesap 15 dk kilitlenir. failureFactor=5, wait/maxFailureWait=900 sn (15 dk), permanentLockout=false.",
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxTemporaryLockouts": 0,
  "failureFactor": 5,
  "waitIncrementSeconds": 900,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,

  "//_ac4": "AC-4: Sifre en fazla 50 karakter (sunucu tarafi zorlama). Ek olarak min 8 karakter guvenlik varsayilani. Girisin fazla karakteri engellemesi (maxlength) icin 'etiya' login temasi kullanilir.",
  "passwordPolicy": "length(8) and maxLength(50)",

  "//_theme": "AC-1/AC-2/AC-4: Login formunda kullanici adi ve sifre alanlarina maxlength=50 uygulayan ve kullanici adinin bas/son bosluklarini kirpan ozel tema.",
  "loginTheme": "etiya",

  "registrationAllowed": false,
  "registrationEmailAsUsername": false,
  "editUsernameAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "roles": {
    "realm": [
      {
        "name": "crm_user",
        "description": "CRM son kullanicisi - standart okuma/yazma yetkileri"
      },
      {
        "name": "crm_admin",
        "description": "CRM yoneticisi - tam yetki"
      }
    ]
  },

  "clients": [
    {
      "clientId": "crm-app",
      "name": "Etiya CRM Lite - Uygulama Istemcisi",
      "description": "Frontend / test istemcisi. Standart Authorization Code + Direct Access Grant (password) akislarini destekler.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    }
  ],

  "//_users": "Ornek kullanici. Giris: demo / Password123 (min 8 / max 50 politikasina uygun).",
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Kullanici",
      "email": "demo@etiya.com",
      "credentials": [
        {
          "type": "password",
          "value": "Password123",
          "temporary": false
        }
      ],
      "realmRoles": ["crm_user"]
    },
    {
      "username": "admin-crm",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "CRM",
      "email": "admin-crm@etiya.com",
      "credentials": [
        {
          "type": "password",
          "value": "Password123",
          "temporary": false
        }
      ],
      "realmRoles": ["crm_user", "crm_admin"]
    }
  ],

  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\",\"displayName\":\"${username}\",\"validations\":{\"length\":{\"min\":3,\"max\":50},\"username-prohibited-characters\":{},\"up-username-not-idn-homograph\":{}},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"email\",\"displayName\":\"${email}\",\"validations\":{\"email\":{},\"length\":{\"max\":255}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"firstName\",\"displayName\":\"${firstName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false},{\"name\":\"lastName\",\"displayName\":\"${lastName}\",\"validations\":{\"length\":{\"max\":255},\"person-name-prohibited-characters\":{}},\"required\":{\"roles\":[\"user\"]},\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\",\"user\"]},\"multivalued\":false}],\"groups\":[{\"name\":\"user-metadata\",\"displayHeader\":\"User metadata\",\"displayDescription\":\"Attributes, which refer to user metadata\"}]}"
          ]
        }
      }
    ]
  }
}

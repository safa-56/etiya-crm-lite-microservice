# =============================================================================
# infra/.env  (bu dosyayı .env olarak kopyalayabilirsiniz; default'lar da çalışır)
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=customerdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# --- Redis / RedisInsight ---
REDIS_PORT=6379
REDISINSIGHT_PORT=5540

# --- Kafka (LOCAL container / KRaft) ---
# Host'tan erişim portu (uygulama dev profilinde localhost:9092 kullanır).
KAFKA_EXTERNAL_PORT=9092
# Kafka UI portu (http://localhost:8090)
KAFKAUI_PORT=8090

# --- Debezium Kafka Connect ---
CONNECT_PORT=8083

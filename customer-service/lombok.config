# Lombok'un ürettiği constructor parametrelerine bazı anotasyonları kopyalamasını sağlar.
# @Lazy'nin @RequiredArgsConstructor ile üretilen constructor'a taşınması, döngüsel
# bağımlılıkların (ör. IndividualCustomerManager <-> Address/ContactInfo servisleri)
# kırılabilmesi için gereklidir.
config.stopBubbling = true
lombok.copyableAnnotations += org.springframework.context.annotation.Lazy
